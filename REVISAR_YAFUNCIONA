        pt_min = (z_v[idx_inf_izq], y_v[idx_inf_izq], sigma_v[idx_inf_izq])

        z_c = np.mean(z_v)
        y_c = np.mean(y_v)

        def offset_esquina(z_pt, y_pt, escala=0.35):
