    t = ax_info.table(cellText=tabla[1:], colLabels=tabla[0],
                      loc='center', cellLoc='center')
    t.auto_set_font_size(False)
    t.set_fontsize(9)
    t.scale(1.1, 1.6)
    for j in range(2):
        t[(0,j)].set_facecolor('#2c3e50')
        t[(0,j)].set_text_props(color='white', fontweight='bold')
    for row_i in range(1, len(tabla)):
        try:
            v = float(tabla[row_i][1])
            if 'σ' in tabla[row_i][0]:
