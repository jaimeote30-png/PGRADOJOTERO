# ============================================================================
# DIAGRAMAS LATERALES: Vz, My y Deflexión Lateral
# ============================================================================

# ============================================================================
# θx = dv/dx POR HERMITE → q_lat TOTAL → DIAGRAMA My LATERAL
# ============================================================================

# ── 1. θx(x) continuo por Hermite ────────────────────────────────────
x_theta      = []
theta_x_cont = []

for i in range(num_nodos - 1):
    Ls_ = nodos[i+1] - nodos[i]
    if Ls_ <= 0:
        continue
    vi_  = u_global[i*7 + 1];     tzi_ = u_global[i*7 + 5]
    vj_  = u_global[(i+1)*7 + 1]; tzj_ = u_global[(i+1)*7 + 5]

    for xl in np.linspace(0, Ls_, 60):
        xi_ = xl / Ls_
        dN1_dx = (-6*xi_ + 6*xi_**2) / Ls_
        dN2_dx =   1 - 4*xi_ + 3*xi_**2
        dN3_dx = ( 6*xi_ - 6*xi_**2) / Ls_
        dN4_dx =  -2*xi_ + 3*xi_**2
        theta_pt = dN1_dx*vi_ + dN2_dx*tzi_ + dN3_dx*vj_ + dN4_dx*tzj_
        x_theta.append(nodos[i] + xl)
        theta_x_cont.append(theta_pt)

x_theta      = np.array(x_theta)
theta_x_cont = np.array(theta_x_cont)

# ── 2. Carga lateral TOTAL: alpha (inclinación) + θx (giro deformada) 
# q·sin(alpha) = componente horizontal del peso propio por inclinación
# q·sin(θx)   = componente lateral por giro de la sección en la deformada
# Ambas actúan en la misma dirección lateral
q_alpha_cont = q * np.sin(alpha)                          # constante
q_theta_cont = q * np.sin(theta_x_cont)                   # variable
q_lat_cont   = q_alpha_cont + q_theta_cont                 # total

print(f"\n  q por inclinación (alpha={Grados}°): {q_alpha_cont:.6f} kN/m")
print(f"  q_lat por θx máximo:                {np.max(np.abs(q_theta_cont)):.6f} kN/m")
print(f"  q_lat total máximo:                 {np.max(np.abs(q_lat_cont)):.6f} kN/m")

# ── 3. Reacciones laterales en N3 y N7 por equilibrio ────────────────
x_N3 = nodos[2];  x_N7 = nodos[6]
L_vano_lat = x_N7 - x_N3

Q_lat_total = np.trapz(q_lat_cont, x_theta)

def momento_respecto_a(x_arr, q_arr, x_ref):
    return np.trapz(q_arr * (x_arr - x_ref), x_arr)

M_lat_N3 = momento_respecto_a(x_theta, q_lat_cont, x_N3)

R_w7_lat = M_lat_N3 / L_vano_lat
R_w3_lat = Q_lat_total - R_w7_lat

print(f"\nREACCIONES LATERALES:")
print(f"  R_w3 = {R_w3_lat:.6f} kN")
print(f"  R_w7 = {R_w7_lat:.6f} kN")
print(f"  Suma = {R_w3_lat+R_w7_lat:.6f} kN  |  Q_lat_total = {Q_lat_total:.6f} kN")

# ── 4. Equilibrio acumulado lateral → Vz(x) y My(x) ─────────────────
# Convención: q_lat actúa como carga distribuida lateral (↓ en z)
# Vz se acumula igual que Vy en el vertical
# My = integral de Vz (igual que Mz = integral de Vy)

x_saltos_lat = {x_N3: R_w3_lat, x_N7: R_w7_lat}
x_eval_lat   = np.sort(np.unique(np.concatenate([
    x_theta, np.array([x_N3, x_N7])])))

x_lat   = [x_eval_lat[0]]
Vz_lat  = [0.0]
My_lat  = [0.0]

Vz_acum = 0.0
My_acum = 0.0
x_prev  = x_eval_lat[0]

for x_cur in x_eval_lat[1:]:
    mask_seg = (x_theta >= x_prev) & (x_theta <= x_cur)
    if mask_seg.sum() > 1:
        xs = x_theta[mask_seg]
        qs = q_lat_cont[mask_seg]
        dQ = np.trapz(qs, xs)           # carga total en el segmento
        dM = np.trapz(qs * (x_cur - xs), xs)  # momento en x_cur
    else:
        dQ = 0.0; dM = 0.0

    # My acumula: Vz·dx - integral de q_lat·(x_cur - x)·dx
    My_acum += Vz_acum * (x_cur - x_prev) - dM
    Vz_acum -= dQ   # q_lat reduce Vz (igual que peso propio reduce Vy)

    Fc_lat = x_saltos_lat.get(x_cur, 0.0)
    if abs(Fc_lat) > 1e-10:
        x_lat.append(x_cur);  Vz_lat.append(Vz_acum)
        My_lat.append(My_acum)
        Vz_acum += Fc_lat     # reacción sube Vz

    x_lat.append(x_cur);  Vz_lat.append(Vz_acum)
    My_lat.append(My_acum)
    x_prev = x_cur

x_lat  = np.array(x_lat)
Vz_lat = np.array(Vz_lat)
My_lat = np.array(My_lat)

My_nodos = np.interp(nodos, x_lat, My_lat)

print(f"\n  My_max = {np.max(np.abs(My_lat)):.6f} kN·m")
print(f"\n  My en nodos:")
for i in range(num_nodos):
    print(f"    N{i+1} @ x={nodos[i]:.2f}m : My = {My_nodos[i]:.6f} kN·m")

# ── 5. Deflexión lateral continua por Hermite (w y θy) ───────────────
x_defl_lat = []
w_defl     = []

for i in range(num_nodos - 1):
    Ls_ = nodos[i+1] - nodos[i]
    if Ls_ <= 0:
        continue
    wi_  = u_global[i*7 + 2];      tyi_ = -u_global[i*7 + 4]   # signo θy
    wj_  = u_global[(i+1)*7 + 2];  tyj_ = -u_global[(i+1)*7 + 4]

    for xl in np.linspace(0, Ls_, 60):
        xi_ = xl / Ls_
        N1 = 1 - 3*xi_**2 + 2*xi_**3
        N2 = Ls_*(xi_ - 2*xi_**2 + xi_**3)
        N3 = 3*xi_**2 - 2*xi_**3
        N4 = Ls_*(-xi_**2 + xi_**3)
        w_pt = N1*wi_ + N2*tyi_ + N3*wj_ + N4*tyj_
        x_defl_lat.append(nodos[i] + xl)
        w_defl.append(w_pt * 1000)  # mm

