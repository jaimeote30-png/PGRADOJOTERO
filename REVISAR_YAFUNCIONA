        ax_sec.annotate(
            f"σ_inf-izq\n{pt_min[2]:.3f} MPa",
            xy=(pt_min[0], pt_min[1]),
            xytext=(pt_min[0] + dz_min, pt_min[1] + dy_min),
            fontsize=8, color='darkblue', fontweight='bold',
            ha='center',
            arrowprops=dict(arrowstyle='->', color='darkblue', lw=2),
            bbox=dict(boxstyle='round', facecolor='white',
                      edgecolor='darkblue', alpha=0.95))

    ax_sec.plot(pt_max[0], pt_max[1], 'r*', ms=14, zorder=6)
    ax_sec.plot(pt_min[0], pt_min[1], 'b*', ms=14, zorder=6)

    sigma_max_val = pt_max[2]
    sigma_min_val = pt_min[2]

    ax_sec.set_aspect('equal')
    ax_sec.set_xlabel('z (m)', fontsize=9)
    ax_sec.set_ylabel('y (m)', fontsize=9)
    titulo_nodo = f'N{nodo_idx+1}' if nodo_idx >= 0 else f'x={x_pos:.4f} m'
    ax_sec.set_title(
        f'{titulo_nodo}\nθx={Grados}°',
        fontsize=10, fontweight='bold')
    ax_sec.grid(True, alpha=0.2)

    # ── Tabla ─────────────────────────────────────────────────────────
    ax_info.axis('off')
    tabla = [
        ['Parámetro',    'Valor'],
        ['x (m)',        f'{x_pos:.3f}'],
        ['Mz (kN·m)',    f'{Mz_kNm:.2f}'],
        ['My (kN·m)',    f'{My_kNm:.4f}'],
        ['N_axial (kN)', f'{N_kN:.1f}'],
        ['θx (°)',       f'{np.rad2deg(theta_x):.5f}'],
        ['σ_max (MPa)',  f'{sigma_max_val:.4f}'],
        ['σ_min (MPa)',  f'{sigma_min_val:.4f}'],
