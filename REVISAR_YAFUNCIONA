from matplotlib.path import Path
from matplotlib.patches import PathPatch
from matplotlib.colors import Normalize
from matplotlib.cm import ScalarMappable
import matplotlib.cm as cm

def get_vertices_PCI_VI():
    D1=1.829; D2=0.127; D3=0.076; D5=0.254; D6=0.203
    B1=1.067; B2=0.711; B3=0.203; B4=0.102
    yc = 0.9140
    y_top = D1 - yc
    x2 = B1/2
    v = []
    v.append([-B1/2,  y_top])
    v.append([ B1/2,  y_top])
    v.append([ B1/2,  y_top - D2])
    v.append([ x2-(B1-B2)/2+B3/2, y_top-D2-D3])
    v.append([ B3/2,  y_top-D2-D3])
    v.append([ B3/2, -yc+D6+D5])
    v.append([ B3/2+B4, -yc+D6+D5])
    v.append([ B2/2, -yc+D6])
    v.append([ B2/2, -yc])
    v.append([-B2/2, -yc])
    v.append([-B2/2, -yc+D6])
    v.append([-(B3/2+B4), -yc+D6+D5])
    v.append([-B3/2, -yc+D6+D5])
    v.append([-B3/2,  y_top-D2-D3])
    v.append([-(x2-(B1-B2)/2+B3/2), y_top-D2-D3])
    v.append([-B1/2,  y_top-D2])
    return np.array(v)

def rotar_vertices(verts, theta):
    c, s = np.cos(theta), np.sin(theta)
    R = np.array([[c, -s],[s,  c]])
    return verts @ R.T

def calcular_sigma_seccion(verts_rot, N_kN, Mz_kNm, My_kNm, n=150):
    y_min, y_max = verts_rot[:,1].min(), verts_rot[:,1].max()
    z_min, z_max = verts_rot[:,0].min(), verts_rot[:,0].max()
    zg, yg = np.meshgrid(np.linspace(z_min, z_max, n),
                          np.linspace(y_min, y_max, n))
    path  = Path(verts_rot)
    pts   = np.column_stack([zg.ravel(), yg.ravel()])
    mask  = path.contains_points(pts).reshape(zg.shape)
    sigma = (N_kN / PA) - (Mz_kNm * yg / PIF) + (My_kNm * zg / PID)  # kPa
    sigma_MPa = np.ma.masked_where(~mask, sigma / 1000)
    return zg, yg, sigma_MPa, mask

def graficar_seccion(ax_sec, ax_info, nodo_idx, x_pos, Mz_val, My_val, theta_x):

    N_kN   = -P_pretensado if CONSIDERAR_PRETENSADO else 0.0
    Mz_kNm = Mz_val
    My_kNm = My_val

    verts_orig = get_vertices_PCI_VI()

    # Si Grados=0 no rotar la sección visualmente
    theta_visual = theta_x if Grados != 0 else 0.0
    verts_rot  = rotar_vertices(verts_orig, theta_visual)

    zg, yg, sigma, mask = calcular_sigma_seccion(verts_rot, N_kN, Mz_kNm, My_kNm)

    vmax = max(abs(float(sigma.min())), abs(float(sigma.max())))
    if vmax < 1e-6: vmax = 1.0
    norm = Normalize(vmin=-vmax, vmax=vmax)
    cmap = cm.RdBu_r

    cf = ax_sec.contourf(zg, yg, sigma, levels=40,
                          cmap=cmap, norm=norm, extend='both')
    try:
        ax_sec.contour(zg, yg, sigma, levels=[0],
                       colors='black', linewidths=2, linestyles='--')
    except Exception:
        pass

    patch_verts = np.vstack([verts_rot, verts_rot[0]])
    ax_sec.plot(patch_verts[:,0], patch_verts[:,1], 'k-', linewidth=2)
    plt.colorbar(cf, ax=ax_sec, label='σ (MPa)', fraction=0.03, pad=0.04)

    y_v = verts_rot[:, 1]
    z_v = verts_rot[:, 0]
    sigma_v = (N_kN/PA - Mz_kNm*y_v/PIF + My_kNm*z_v/PID) / 1000

    if Grados == 0:
        # flechas al centro del ala superior e inferior, sin rotación
        y_sup_val = y_v.max()
        y_inf_val = y_v.min()

        mask_sup = np.abs(y_v - y_sup_val) < 1e-3
        z_sup_c  = np.mean(z_v[mask_sup]) if mask_sup.any() else 0.0

        mask_inf = np.abs(y_v - y_inf_val) < 1e-3
        z_inf_c  = np.mean(z_v[mask_inf]) if mask_inf.any() else 0.0

        s_sup = (N_kN/PA - Mz_kNm*y_sup_val/PIF + My_kNm*z_sup_c/PID) / 1000
        s_inf = (N_kN/PA - Mz_kNm*y_inf_val/PIF + My_kNm*z_inf_c/PID) / 1000

        pt_max = (z_sup_c, y_sup_val, s_sup)
