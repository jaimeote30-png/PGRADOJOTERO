K_global = np.zeros((ndof_total, ndof_total))

def matriz_elemental(Ls):
    if Ls <= 0:
        return None

    valores = {
         "A": (E*A)/Ls,
        "B": (12*E*Iz)/(Ls**3),      # ✓ Usa Iz para v
        "C": (12*E*Iy)/(Ls**3),      # ✓ Usa Iy para w
        "D": ((6*G_shear*J)/(5*Ls))+((12*E*Cw)/(Ls**3)),
        "E": (4*E*Iy)/Ls,             # ✓ Usa Iy para θy
        "F": (4*E*Iz)/Ls,             # ✓ Usa Iz para θz
        "G": (6*E*Iz)/(Ls**2),       # ✓ Usa Iz para acoplamiento v-θz
        "H": (6*E*Iy)/(Ls**2),       # ✓ Usa Iy para acoplamiento w-θy
        "I": ((G_shear*J)/(10))+((6*E*Cw)/(Ls**2)),
        "J": ((G_shear*J*Ls)/(30))-((2*E*Cw)/(Ls)),
        "K": ((2*G_shear*J*Ls)/(15))+((4*E*Cw)/(Ls)),
        "L": (E*Iy*2)/Ls,             # ✓ Usa Iy
        "M": (E*Iz*2)/Ls              # ✓ Usa Iz
    }
    


    def convertir(valor):
        if valor == "0":
            return 0.0
        if valor.startswith("-"):
            return -valores[valor[1:]]
        return valores[valor]

    return np.vectorize(convertir)(K_letras)

