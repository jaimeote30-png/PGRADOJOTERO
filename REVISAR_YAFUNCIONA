def fef_elemento(Ls_, q, alpha=0.0):
    """Fuerzas de empotramiento perfecto — peso propio distribuido"""
    qv = q * np.cos(alpha)
    qh = q * np.sin(alpha)
    fef = np.zeros(14)
    fef[1]  = -(qv * Ls_) / 2          # v_i
    fef[2]  = -(qh * Ls_) / 2          # w_i
    fef[4]  = -(qh * Ls_**2) / 12      # θy_i
    fef[5]  = -(qv * Ls_**2) / 12      # θz_i
    fef[8]  = -(qv * Ls_) / 2          # v_j
    fef[9]  = -(qh * Ls_) / 2          # w_j
    fef[11] = +(qh * Ls_**2) / 12      # θy_j
    fef[12] = +(qv * Ls_**2) / 12      # θz_j
    return fef

def fef_pretensado_elemento(Ls_, i_elem, P, e, L_total, nodos):
    """Fuerzas de empotramiento perfecto — pretensado (cargas en L/3 y 2L/3)"""
    fef = np.zeros(14)
    xi = nodos[i_elem]
    xj = nodos[i_elem + 1]
    P_carga = 3 * P * e / L_total

    for pos_c in [L_total / 3, 2 * L_total / 3]:
        if xi <= pos_c <= xj:
            a_c = pos_c - xi
            b_c = xj - pos_c
            Ri  =  P_carga * b_c**2 * (3*a_c + b_c) / Ls_**3
            Rj  =  P_carga * a_c**2 * (a_c + 3*b_c) / Ls_**3
            Mi  =  P_carga * a_c * b_c**2 / Ls_**2
            Mj  = -P_carga * a_c**2 * b_c / Ls_**2
            fef[1]  += Ri;  fef[5]  += Mi
            fef[8]  += Rj;  fef[12] += Mj

    F_vert_ext = 3 * P * e / L_total
    if i_elem == 0:               fef[1] -= F_vert_ext   # extremo izq
    if i_elem == num_nodos - 2:   fef[8] -= F_vert_ext   # extremo der

    if i_elem == 0:               fef[0] += P            # axial izq
    if i_elem == num_nodos - 2:   fef[7] -= P            # axial der

    return fef

# ══════════════════════════════════════════════════════════════════════
