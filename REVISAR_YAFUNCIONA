            f"σ=inf\n{pt_min[2]:.3f} MPa",
            xy=(pt_min[0], pt_min[1]),
            xytext=(pt_min[0], pt_min[1] - 0.25),
            fontsize=8, color='darkblue', fontweight='bold',
            ha='center',
            arrowprops=dict(arrowstyle='->', color='darkblue', lw=2),
            bbox=dict(boxstyle='round', facecolor='white',
                      edgecolor='darkblue', alpha=0.95))

    else:
        # CON giro: rojo = esquina sup-der, azul = esquina inf-izq
        score_sup_der = y_v + z_v
        score_inf_izq = -(y_v + z_v)

        idx_sup_der = np.argmax(score_sup_der)
        idx_inf_izq = np.argmax(score_inf_izq)

